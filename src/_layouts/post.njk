---
layout: simple-base.njk
---

<article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-8">
        <div class="mb-4">
            <a href="/blog/" class="inline-flex items-center gap-2 text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors duration-200">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Blog
            </a>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
            {{ title }}
        </h1>
        <div class="flex items-center gap-4 text-gray-600 dark:text-gray-300">
            <time datetime="{{ date | date('YYYY-MM-DD') }}">
                {{ date | dateDisplay }}
            </time>
            {% if tags %}
                <div class="flex items-center gap-2">
                    {% for tag in tags %}
                        {% if tag != "post" %}
                            <span class="px-2 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 text-sm rounded-md">
                                {{ tag }}
                            </span>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </header>

    <div class="prose prose-lg dark:prose-invert prose-primary max-w-none">
        {{ content | safe }}
    </div>
</article>